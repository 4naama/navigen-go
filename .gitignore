# 🔐 Environment / Secrets
.env
.env.*             # includes .env.local, .env.production, etc.
*.secrets
*.key
*.pem
*.crt
*.pfx
*.db
*.sqlite
*.sqlite3

# 🪵 Logs
*.log
logs/
