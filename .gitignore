frontend/public/**/*.md
frontend/public/**/*.mdx

# Do not commit private data or local data snapshots
frontend/data-safe/
frontend/public/data-safe/
public/data/data-safe/
!frontend/public/data-safe/.gitkeep
!public/data/data-safe/.gitkeep

# backend worker artifacts
backend/worker/node_modules/
backend/worker/package-lock.json
/frontend/wrangler.toml
/navigen-go/

